# ============================================================
# BACKEND — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a GitHub
# ============================================================

# Servidor
NODE_ENV=development
PORT=3001
API_VERSION=v1

# Base de datos (PostgreSQL / Supabase)
DATABASE_URL=postgresql://usuario:password@localhost:5432/condominio_saas
# Para Supabase usar el connection string de: Settings > Database > Connection string
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Supabase (para Storage y Auth)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_aqui
SUPABASE_ANON_KEY=tu_anon_key_aqui

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tucondominioapp.cl
EMAIL_FROM_NAME=Condominio App

# Web Push Notifications (VAPID)
VAPID_PUBLIC_KEY=genera_con_npx_web-push_generate-vapid-keys
VAPID_PRIVATE_KEY=genera_con_npx_web-push_generate-vapid-keys
VAPID_SUBJECT=mailto:admin@tucondominioapp.cl

# CORS (dominios permitidos)
CORS_ORIGINS=http://localhost:5173,https://tudominio.vercel.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Uploads (Cloudinary - opcional)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Alertas parking (minutos antes de vencimiento)
PARKING_ALERT_MINUTES_BEFORE=30
